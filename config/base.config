
CONFIG_HUGETLBFS=y                  # already enabled
CONFIG_HUGETLB_PAGE=y               # enable hugetlb support
CONFIG_TRANSPARENT_HUGEPAGE_NEVER=y # disable THP to force explicit hugepage use
CONFIG_EXT4_FS=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y

CONFIG_VFIO_PCI=y                   # already enabled
CONFIG_VFIO=y                       # core VFIO framework
CONFIG_VFIO_IOMMU_TYPE1=y           # VFIO IOMMU driver
CONFIG_VFIO_VIRQFD=y                # VFIO eventfds for interrupt delivery

CONFIG_NO_HZ_FULL=y                 # already enabled
CONFIG_NO_HZ_IDLE=y                 # full nohz support for idle (paired with NO_HZ_FULL)
CONFIG_HZ_1000=y                    # 1 kHz tick for finer scheduling granularity
CONFIG_HIGH_RES_TIMERS=y            # high-resolution timer support

CONFIG_NUMA=y                       # already enabled
CONFIG_ZONE_DMA_CMA=y               # allow CMA allocations for DMA

CONFIG_IOMMU_DMA=y                  # generic IOMMU DMA support
CONFIG_IOMMU_PASSTHROUGH=y          # bypass IOMMU for DMA (matches iommu.passthrough=1)

CONFIG_XDP_SOCKETS=y                # AF_XDP socket support in-kernel
CONFIG_AF_XDP=y                     # user-space fast packet I/O

CONFIG_RFS_ACCEL=y                  # Receive Flow Steering accelerator

# CPU power & performance
CONFIG_CPU_FREQ=y                   # CPUFreq core
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_ACPI_CPU_FREQ_PSS=y          # ACPI P‐states for stable frequencies

# Network offloads (if using hardware offload)
CONFIG_NET_RX_BUSY_POLL=y           # busy‐polling support for low‐latency dequeue
CONFIG_RX_RING_FANOUT=y             # RSS fanout steering

# Virtualization hooks (optional, if using VMs with DPDK)
CONFIG_KVM=y
CONFIG_VHOST_NET=y
