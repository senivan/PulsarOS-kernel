# DPDK-Optimized Kernel Config Fragment

############################################################
# 1. Hugepages & Memory
############################################################
CONFIG_HUGETLBFS=y                  # HugeTLB filesystem
CONFIG_HUGETLB_PAGE=y               # support huge pages
CONFIG_TRANSPARENT_HUGEPAGE_NEVER=y # force explicit hugepage allocation

############################################################
# 2. Userspace I/O & VFIO
############################################################
CONFIG_UIO=y                        # Userspace I/O framework
CONFIG_UIO_PCI_GENERIC=y            # generic PCI UIO binding
CONFIG_VFIO=y                       # VFIO core
CONFIG_VFIO_PCI=y                   # VFIO PCI support
CONFIG_VFIO_IOMMU_TYPE1=y           # VFIO IOMMU driver
CONFIG_VFIO_VIRQFD=y                # VFIO eventfds for interrupts
CONFIG_IOMMU_DMA=y                  # DMA through IOMMU
CONFIG_IOMMU_PASSTHROUGH=y          # bypass IOMMU for performance

############################################################
# 3. Timing & CPU Isolation Helpers
############################################################
CONFIG_NO_HZ_FULL=y                 # full dynticks CPUs
CONFIG_NO_HZ_IDLE=y                 # idle dynticks support
CONFIG_HZ_1000=y                    # 1000 Hz timer tick
CONFIG_HIGH_RES_TIMERS=y            # high-res timers
CONFIG_HPET=y                       # High Precision Event Timer
CONFIG_HPET_MMAP=y                  # mmap HPET for user-space

############################################################
# 4. NUMA & DMA Zones
############################################################
CONFIG_NUMA=y                       # Non-Uniform Memory Access
CONFIG_ZONE_DMA_CMA=y               # CMA for DMA allocations

############################################################
# 5. Networking & Packet I/O
############################################################
CONFIG_XDP_SOCKETS=y                # AF_XDP socket support
CONFIG_AF_XDP=y                     # user-space fast packet I/O
CONFIG_RFS_ACCEL=y                  # Receive Flow Steering accelerator
CONFIG_NET_RX_BUSY_POLL=y           # busy polling for low-latency RX
CONFIG_RX_RING_FANOUT=y             # RSS fanout

############################################################
# 6. CPU Power & Performance
############################################################
CONFIG_CPU_FREQ=y                   # CPU frequency scaling core
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_ACPI_CPU_FREQ_PSS=y          # ACPI P‑states

############################################################
# 7. Filesystems & Debug (Disabled)
############################################################
# Keep EXT4 support if you need rootfs on ext4; otherwise disable extra FS
CONFIG_EXT4_FS=y

# Disable debugging/audit to reduce latency
CONFIG_DEBUG_INFO=n
CONFIG_AUDIT=n
CONFIG_DEBUG_INFO_BTF=n
CONFIG_BPF_SYSCALL=n
CONFIG_BLK_DEV_DM=y
CONFIG_DM_THIN_PROVISIONING=y   # LVM thin pools support
CONFIG_DM_SNAPSHOT=y            # Snapshot support
CONFIG_LZMA_DECOMPRESS=y
CONFIG_INITRAMFS_COMPRESSION_LZMA=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_LOWLEVEL=y